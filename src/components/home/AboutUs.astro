---
import AboutUsImage from '../../assets/about/about_image.jpg'
import AboutUsSmallImage1 from '../../assets/about/about_small_image_1.jpg'
import AboutUsSmallImage2 from '../../assets/about/about_small_image_2.jpg'
---
<section class="aboutus" id="aboutus">
    <div class="aboutus__header">
        <span class="aboutus__label">ABOUT US</span>
        <a href="aboutus" class="aboutus__more">MORE ABOUT US</a>
    </div>

    <div class="aboutus__hero">
        <p class="aboutus__tagline">
            Founded in 1999, Nam Phương is a family-led company of engineers and architects,
            working across design and construction. Our strength lies in the collective — a team
            of specialists from different disciplines, aligned by a shared mindset and a
            hands-on approach
        </p>
    </div>
    <div class="aboutus__body">
        <div class="aboutus__image-wrapper">
            <img src={AboutUsImage.src} alt="About Us Image" class="aboutus__image" />
        </div>
        
        <div class="aboutus__content">
            <h2 class="aboutus__milestone">25 Years of building with balance</h2>
            
            <div class="aboutus__cols">
                <div class="aboutus__col">
                    <p class="aboutus__col-text">
                        A quarter century of ideas, spaces, and structures. For 25 years, Nam Phương
                        has stood at the intersection of design and construction — shaping homes,
                        workplaces, and environments with intention and care.
                    </p>
                </div>

                <div class="aboutus__col">
                    <p class="aboutus__col-text">
                        What began as a family-driven studio in 1999 has grown into a trusted name in
                        architecture and building, defined by collaboration, craft, and the pursuit of
                        balance. We're proud of what we've built — and what's next.
                    </p>                
                </div>
                
            
            </div>
            <div class="aboutus__images">
                <div class="aboutus__col-img-wrapper">
                    <img src={AboutUsSmallImage1.src} alt="About Us Image" class="aboutus__col-img" />
                </div>

                <div class="aboutus__col-img-wrapper">
                    <img src={AboutUsSmallImage2.src} alt="About Us Image" class="aboutus__col-img" />
                </div>
            </div>
        </div>
    </div>

</section>

<style>
    .aboutus {
        background: #e8e4de;
        padding: 80px 40px 120px;
        overflow: hidden;
        user-select: none;
        text-align: justify;
    }

    /* Header */
    .aboutus__header {
        font-family: var(--font-family-display);
        font-weight: var(--font-weight-semibold);

        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }
    .aboutus__label {
        font-size: 20px;
        color: black;
    }
    .aboutus__more {
        font-size: 20px;
        color: #1a1714;
        text-decoration: none;

        padding-bottom: 4px;            
        background-image: linear-gradient(#1a1714, #1a1714);
        background-position: 50% 100%; 
        background-repeat: no-repeat;   
        background-size: 100% 1.5px;
        transition: background-size 0.4s ease;
    }
    .aboutus__more:hover {
        background-size: 0% 1.5px;
    }

    /* Hero */
    .aboutus__hero {
        max-width: 100%;
        margin: 0 auto;
    }
    .aboutus__tagline {
        font-family: var(--font-family-body);
        font-size: 30px;
        font-weight: var(--font-weight-regular);
        line-height: 1.35;
        margin: 0;
    }

    /* Body */
    .aboutus__body {
        padding-top: 100px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0px 150px;
        align-items: start;
    }
    
    .aboutus__image-wrapper {
        height: 600px;
        width: 500px;
        position: relative;
        overflow: hidden;
        border-radius: 5px;
    }
    .aboutus__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .aboutus__content {
        flex: 1;
    }
    .aboutus__milestone {
        font-size: clamp(22px, 2.2vw, 30px);
        font-weight: 400;
        line-height: 1.28;
        letter-spacing: -0.01em;
        color: #000000;
        margin: 0 0 36px;
    }
    .aboutus__cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
    }
    .aboutus__col {
        margin: 0;
    }
    .aboutus__col-text {
        font-size: clamp(13px, 1.1vw, 16px);
        line-height: 1.72;
        color: var(--color-muted);
        margin: 0;
    }
    .aboutus__images {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0px 10px;
        margin-top: 30px;
    }
    .aboutus__col-img-wrapper {
        width: 300px;
        height: 330px;
        overflow: hidden;
        border-radius: 5px;
    }
    .aboutus__col-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .aboutus__image,
    .aboutus__col-img {
        opacity: 0;
        transition: opacity 0.5s ease;
    }

    .aboutus__image.is-visible,
    .aboutus__col-img.is-visible {
        transform: scale(1);
        opacity: 1;
    }
</style>

<script>
    // Fade in cho tất cả ảnh
    const images = document.querySelectorAll('.aboutus__image, .aboutus__col-img');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).style.opacity = '1';
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.2 });
    images.forEach(img => observer.observe(img));

    // Parallax riêng cho từng ảnh
    const parallaxImgs = document.querySelectorAll('.aboutus__image, .aboutus__col-img');
    window.addEventListener('scroll', () => {
        parallaxImgs.forEach(img => {
            const el = img as HTMLElement;
            const rect = el.getBoundingClientRect();
            const scrollY = Math.max(0, -rect.top);
            el.style.transform = `translateY(${scrollY * 0.3}px)`;
        });
    }, { passive: true });
</script>