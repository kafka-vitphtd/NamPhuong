---
import Logo from '../../assets/logo/logo.png'
---
<header class="navbar">
    <div class="navbar__left">
        <a href="/" aria-label="Nam Phương Home">
            <img src={Logo.src} alt="Nam Phương" class="navbar__logo" />
        </a>
        <a href="/" class="navbar__name" aria-label="Nam Phương Home">NAM PHƯƠNG</a>
    </div>
    <div class="navbar__right">
        <button class="navbar__menu" id="menu-button" aria-expanded="false" aria-label="Main Menu">
            <span class="navbar__label" id="menu-label">Menu</span>
            <div class="navbar__hamburger" aria-hidden="true">
                <div class="bars">
                    <div class="bar bar-top"></div>
                    <div class="bar bar-mid"></div>
                    <div class="bar bar-bottom"></div>
                </div>
            </div>
        </button>
    </div>
</header>

<style>
    .navbar {
        position: fixed;
        top: 0; left: 0; right: 0;

        z-index: 200;

        display: flex;
        align-items: center;
        justify-content: space-between;

        height: 110px;
        padding: 0px 40px;
        background: transparent;

        font-family: var(--font-family-display);
        user-select: none;

        transform-origin: top center;
        transition: 
            background 2s cubic-bezier(0.16, 1, 0.3, 1),
            backdrop-filter 2s cubic-bezier(0.16, 1, 0.3, 1),
            -webkit-backdrop-filter 2s cubic-bezier(0.16, 1, 0.3, 1),
            box-shadow 2s cubic-bezier(0.16, 1, 0.3, 1),
            height 2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .navbar__left {
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .navbar__logo {
        height: 50px;
        width: auto;
        filter: brightness(0) invert(1); 
        transform-origin: left center;
        transform: scale(1) translateY(0px);
        transition: 
            filter 2s cubic-bezier(0.16, 1, 0.3, 1),
            transform 2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .navbar__name {
        font-size: 30px;
        font-weight: bold;
        color: #ffffff;
        text-decoration: none;
        transform-origin: left center;
        will-change: transform;
        transform: scale(1) translateX(0px);
        transition: 
            color 2s cubic-bezier(0.16, 1, 0.3, 1),
            transform 2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .navbar__right {
        display: flex;
        align-items: center;
        gap: 30px;
    }
    .navbar__menu {        
        all: unset;
        align-items: center;
        gap: 10px;
        display: flex;
        cursor: pointer;
        position: relative;
        z-index: 300; 
    }
    .navbar__label {
        overflow: hidden;
        font-size: 25px;
        color: #ffffff;
        font-weight: var(--font-weight-medium);
        transition: color 2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    /* Hamburger Menu Styles */
    .navbar__hamburger {
        position: relative;
        width: 40px; height: 40px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .bars {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }
    .bar {
        height: 3px;
        border-radius: 2px;
        background: #ffffff;
        transform-origin: center;
        transition:
            width 1.4s cubic-bezier(0.16, 1, 0.3, 1),
            transform 1.4s cubic-bezier(0.16, 1, 0.3, 1),
            opacity 1.4s ease,
            background 2s cubic-bezier(0.16, 1, 0.3, 1),
            color 2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .bar-top    { width: 25px; }
    .bar-mid    { width: 15px; }
    .bar-bottom { width: 25px; }

    .navbar__menu:not(.open):hover .bar-top    { width: 15px; }
    .navbar__menu:not(.open):hover .bar-mid    { width: 25px; }
    .navbar__menu:not(.open):hover .bar-bottom { width: 15px; }

    .navbar__menu.open .bar-top    { width: 30px; transform: translateY(9px) rotate(45deg); }
    .navbar__menu.open .bar-mid    { opacity: 0; transform: scaleX(0); }
    .navbar__menu.open .bar-bottom { width: 30px; transform: translateY(-9px) rotate(-45deg); }

    .navbar.scrolled {
        height: 65px;
        background: rgba(255, 255, 255, 0.15);  
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 2px 30px rgba(0, 0, 0, 0.05);
    }

    .navbar.scrolled .navbar__logo {
        filter: brightness(0); 
        transform: scale(0.92);
    }

    .navbar.scrolled .navbar__name {
        color: #2a2620; 
        transform: scale(0.92) translateX(-4px);
    }

    .navbar.scrolled .navbar__label {
        color: #2a2620;
    }

    .navbar.scrolled .bar {
        background: #2a2620;
    }

    /* Hover state khi scroll */
    .navbar.scrolled .navbar__menu:hover .navbar__menu-label {
        color: rgba(42, 38, 32, 0.7);
    }

    .navbar__label.slide-up {
        animation: slideUp 0.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }

    .navbar__label.slide-down {
        animation: slideDown 0.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }

    .navbar__label.slide-from-top {
        animation: slideFromTop 0.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }

    .navbar__label.slide-from-bottom {
        animation: slideFromBottom 0.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(0); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes slideUp {
        0% {
            transform: translateY(0);
            opacity: 1;
        }
        100% {
            transform: translateY(-100%);
            opacity: 0;
        }
    }

    @keyframes slideDown {
        0% {
            transform: translateY(0);
            opacity: 1;
        }
        100% {
            transform: translateY(100%);
            opacity: 0;
        }
    }

    @keyframes slideFromTop {
        0% {
            transform: translateY(-100%);
            opacity: 0;
        }
        100% {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @keyframes slideFromBottom {
        0% {
            transform: translateY(100%);
            opacity: 0;
        }
        100% {
            transform: translateY(0);
            opacity: 1;
        }
    }
</style>

<script>
    // ── Scroll Handler ──
    const navbar = document.querySelector('.navbar') as HTMLElement;
    let ticking = false;

    function updateNavbar() {
        if (window.scrollY > 50) {
            navbar.classList.add('scrolled');
        } else {
            navbar.classList.remove('scrolled');
        }
        ticking = false;
    }

    window.addEventListener('scroll', () => {
        if (!ticking) {
            requestAnimationFrame(updateNavbar);
            ticking = true;
        }
    }, { passive: true });

    // ── Menu Toggle Handler ──
    const menuButton = document.getElementById('menu-button') as HTMLButtonElement;
    const panel   = document.getElementById('dropdown-panel') as HTMLElement;

    let labelAnimationCleanup: (() => void) | null = null;

    function animateLabel(
        label: HTMLElement,
        exitClass: string,
        enterClass: string,
        newText: string
    ) {
        if (labelAnimationCleanup) {
            labelAnimationCleanup();
            labelAnimationCleanup = null;
        }

        label.classList.remove('slide-up', 'slide-down', 'slide-from-top', 'slide-from-bottom');

        label.classList.add(exitClass);

        const onExitEnd = () => {
            label.classList.remove(exitClass);
            label.textContent = newText;

            label.classList.add(enterClass);

            const onEnterEnd = () => {
                label.classList.remove(enterClass);
                labelAnimationCleanup = null;
            };

            label.addEventListener('animationend', onEnterEnd, { once: true });
        };

        label.addEventListener('animationend', onExitEnd, { once: true });

        labelAnimationCleanup = () => {
            label.removeEventListener('animationend', onExitEnd);
            label.classList.remove(exitClass, enterClass);
            label.textContent = newText;  
        };
    }

    function openMenu() {
        panel.classList.add('is-open');
        panel.removeAttribute('aria-hidden');
        menuButton.classList.add('open');
        menuButton.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';

        const label = document.getElementById('menu-label') as HTMLElement;
        animateLabel(label, 'slide-up', 'slide-from-bottom', 'Close');
    }

    function closeMenu() {
        panel.classList.remove('is-open');
        panel.setAttribute('aria-hidden', 'true');
        menuButton.classList.remove('open');
        menuButton.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';

        const label = document.getElementById('menu-label') as HTMLElement;
        animateLabel(label, 'slide-down', 'slide-from-top', 'Menu');
    }

    function alignPanel() {
        const btnRect = menuButton.getBoundingClientRect();
        
        const distanceFromRight = window.innerWidth - btnRect.right;
        
        panel.style.right = `${distanceFromRight}px`;
        
        panel.style.left = 'auto'; 
    }
    if (panel) {
        alignPanel();
        window.addEventListener('resize', alignPanel);
    }


    menuButton?.addEventListener('click', () => {
        menuButton.classList.contains('open') ? closeMenu() : openMenu();
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
    });

    panel?.querySelectorAll('.drop-link').forEach(link => {
        link.addEventListener('click', closeMenu);
    });

    document.addEventListener('click', (e) => {
        if (
            menuButton.classList.contains('open') &&
            !panel.contains(e.target as Node) &&
            !menuButton.contains(e.target as Node)
        ) {
            closeMenu();
        }
    });
</script>